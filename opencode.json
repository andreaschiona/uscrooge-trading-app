{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "./gradlew.bat *": "allow",
      "./gradlew *": "allow",
      "git *": "allow",
      "gh *": "allow",
      "*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "tail_turns": 10
  },
  "tool_output": {
    "max_lines": 150,
    "max_bytes": 6144
  },
  "provider": {
    "opencode": {
      "options": {
        "timeout": 120000,
        "chunkTimeout": 30000
      }
    },
    "gemini": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  }
}
